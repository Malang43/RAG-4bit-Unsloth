# Imports
from src.embeddings import load_embedding_model, embed_texts, build_faiss_index
from src.utils import load_documents, chunk_text
from src.rag_pipeline import generate_response

# Load documents
documents = load_documents("data/domain_docs/")
chunks = [chunk for doc in documents for chunk in chunk_text(doc)]

# Load embedding model
tokenizer, embed_model, device = load_embedding_model()

# Create embeddings and FAISS index
embeddings = embed_texts(chunks, tokenizer, embed_model, device)
faiss_index = build_faiss_index(embeddings)

# Test RAG pipeline
query = "Does insurance cover MRI scans?"
answer = generate_response(query, tokenizer, embed_model, device, faiss_index, chunks)
print(answer)
